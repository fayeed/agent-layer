AGENTLAYER_DATABASE_URL=postgres://agentlayer:agentlayer@localhost:5432/agentlayer?sslmode=disable
AGENTLAYER_RAW_STORE=fs
AGENTLAYER_RAW_DATA_DIR=.agentlayer-data/raw
AGENTLAYER_S3_BUCKET=agentlayer-raw
AGENTLAYER_S3_ENDPOINT=http://localhost:9000
AGENTLAYER_S3_PATH_STYLE=true
AGENTLAYER_S3_ACCESS_KEY_ID=minioadmin
AGENTLAYER_S3_SECRET_ACCESS_KEY=minioadmin
AGENTLAYER_AUTO_MIGRATE=true
AGENTLAYER_EMAIL_PROVIDER=dev
AGENTLAYER_ADDR=:8080
AGENTLAYER_SMTP_ADDR=localhost:2525
AGENTLAYER_SMTP_DOMAIN=localhost
AGENTLAYER_WEBHOOK_RETRY_ENABLED=true
AGENTLAYER_WEBHOOK_RETRY_INTERVAL=30s
AGENTLAYER_WEBHOOK_RETRY_LIMIT=20
AWS_REGION=us-east-1
# When AGENTLAYER_EMAIL_PROVIDER=ses, AWS_REGION is required and standard AWS credentials must be available.
# When AGENTLAYER_RAW_STORE=s3, AGENTLAYER_S3_BUCKET and AWS_REGION are required.
# MinIO-compatible local defaults are included above.
# AGENTLAYER_WEBHOOK_URL=http://localhost:3000/webhook
# AGENTLAYER_WEBHOOK_SECRET=dev-secret
